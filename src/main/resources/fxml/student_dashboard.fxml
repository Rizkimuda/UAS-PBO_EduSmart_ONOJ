                                                <Button onAction="#handleCloseQuizResult" styleClass="login-button" text="Tutup Hasil" />
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                    
                                 </children>
                              </StackPane>
                              
                           </children>
                        </HBox>
                        
                     </children>
                  </VBox>
                  
               </children>
            </StackPane>
         </children>
      </VBox>
   </children>
</HBox>
