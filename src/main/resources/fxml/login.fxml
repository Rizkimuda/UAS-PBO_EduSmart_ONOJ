<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" prefHeight="600.0" prefWidth="900.0" styleClass="root-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.edusmart.ui.LoginController">
   <children>
      <!-- Centered Layout Wrapper -->
      <VBox alignment="CENTER" fillWidth="false" spacing="20.0" styleClass="login-layout-wrapper">
         <children>
            
            <!-- Brand Logo & Header above the card -->
            <HBox styleClass="brand-header-container">
               <children>
                  <Label styleClass="brand-header-icon" text="🎓">
                     <font>
                        <Font size="36.0" />
                     </font>
                  </Label>
                  <Label styleClass="brand-header-title" text="EduSmart">
                     <font>
                        <Font name="System Bold" size="26.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            
            <!-- Centered Floating Login Card -->
            <VBox spacing="24.0" styleClass="login-card">
               <children>
                  
                  <!-- Form Title & Subtitle -->
                  <VBox alignment="CENTER" spacing="6.0">
                     <children>
                        <Label styleClass="form-title" text="Selamat Datang Kembali">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <Label styleClass="form-subtitle" text="Silakan masuk untuk mengakses panel kursus Anda" />
                     </children>
                  </VBox>
                  
                  <!-- Input Fields -->
                  <VBox spacing="16.0">
                     <children>
                        <!-- Username field -->
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="Username" />
                              <TextField fx:id="usernameField" promptText="Masukkan username Anda" styleClass="modern-text-field" />
                           </children>
                        </VBox>
                        
                        <!-- Password field with Toggle Button inside StackPane -->
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="Kata Sandi" />
                              <StackPane alignment="CENTER_RIGHT">
                                 <children>
                                    <PasswordField fx:id="passwordField" promptText="Masukkan kata sandi Anda" styleClass="modern-text-field, password-input" />
                                    <TextField fx:id="passwordTextField" promptText="Masukkan kata sandi Anda" styleClass="modern-text-field, password-input" visible="false" managed="false" />
                                     <StackPane fx:id="togglePasswordButton" focusTraversable="false" onMouseClicked="#togglePasswordVisibility" styleClass="eye-button-container" maxWidth="-Infinity" maxHeight="-Infinity" StackPane.alignment="CENTER_RIGHT">
                                        <children>
                                           <!-- Default: Eye Open SVG Path -->
                                           <SVGPath fx:id="eyeIconPath" content="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" scaleX="0.9" scaleY="0.9" styleClass="eye-icon" />
                                        </children>
                                        <StackPane.margin>
                                           <Insets right="12.0" />
                                        </StackPane.margin>
                                     </StackPane>
                                 </children>
                              </StackPane>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <!-- Error Label -->
                  <Label fx:id="errorLabel" managed="false" styleClass="error-feedback" text="" visible="false" wrapText="true" />
                  
                  <!-- Action Button -->
                  <Button fx:id="loginButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" prefHeight="44.0" styleClass="login-button" text="Masuk" />
                  
                  <!-- Demo accounts credentials helper card -->
                  <VBox spacing="6.0" styleClass="helper-card">
                     <padding>
                        <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
                     </padding>
                     <children>
                        <Label styleClass="helper-header" text="AKUN DEMO (Kata Sandi: password123)" />
                        <HBox spacing="14.0">
                           <children>
                              <Label styleClass="helper-credential" text="🔑 admin" />
                              <Label styleClass="helper-credential" text="🔑 instructor" />
                              <Label styleClass="helper-credential" text="🔑 student" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <!-- Register Link -->
                  <HBox alignment="CENTER" spacing="6.0">
                     <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #64748b;" text="Belum punya akun?" />
                        <Label onMouseClicked="#navigateToRegister" style="-fx-font-size: 12px; -fx-text-fill: #2563eb; -fx-font-weight: bold; -fx-cursor: hand;" text="Daftar di sini" />
                     </children>
                  </HBox>
                  
               </children>
            </VBox>
            
         </children>
      </VBox>
   </children>
</StackPane>
